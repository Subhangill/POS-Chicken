@model POS.ViewModel.ProductVM


<div class="page-wrapper cardhead">
    <div class="content">
        <div class="row">
            <div class="col-sm-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="card-title"> @(Model?.product.Id > 0 ? "Update Product " : "New Product  ")</h4>
                        <a asp-action="Index" class="btn btn-primary "><i class="fas fa-list"></i>   List</a>

                    </div>
                    <div class="card-body">
                        <form asp-action="Save" method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="Category" class="form-label">Category </label>
                                        <select asp-for="product.CategoryId"
                                                asp-items="@(new SelectList(Model.categorylist, "Id", "Name"))"
                                                id="search-select"
                                                class=" select"
                                                required>
                                            <option value="">Select Category</option>
                                        </select>
                                    </div>
                                </div>

                            </div>

                            <div class="col-md-12">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label for="Name" class="form-label">Name</label>
                                        <input type="text" asp-for="product.Name" class="form-control" id="Name" placeholder="Enter Name" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="UrduName" class="form-label">Urdu Name</label>
                                        <input type="text" asp-for="product.UrduName" id="UrduName" class="form-control" placeholder="نام درج کریں">
                                    </div>
                                </div>

                            </div>
                            <div class="col-md-12 mt-2">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label for="Price" class="form-label">Price</label>
                                        <input type="number" asp-for="product.Price" class="form-control" id="Price" required>
                                    </div>
                                    <input type="hidden" asp-for="product.Id" />

                                </div>
                            </div>


                            <div class="text-center mt-4">
                                <button type="submit" class="btn btn-primary"> <i class="fas fa-save"></i>   @(Model?.product.Id > 0 ? "Update" : "Save")</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



