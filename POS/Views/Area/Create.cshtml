@model POS.Models.Area

<div class="page-wrapper cardhead">
    <div class="content">
        <div class="row">
            <div class="col-sm-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="card-title"> @(Model?.Id > 0 ? "Update Area " : "New Area  ")</h4>
                        <a asp-action="Index" class="btn btn-primary "><i class="fas fa-list"></i>   List</a>

                    </div>
                    <div class="card-body">
                        <form asp-action="Save" method="post">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="Name" class="form-label">Name</label>
                                        <input type="text" asp-for="Name" class="form-control" id="Name" placeholder="Enter Name" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label for="UrduName" class="form-label">Urdu Name</label>
                                        <input type="text" asp-for="UrduName" id="UrduName" class="form-control" placeholder="نام درج کریں">
                                    </div>
                                    <input type="hidden" asp-for="Id" />

                                </div>
                            </div>

                            <div class="text-center mt-4">
                                <button type="submit" class="btn btn-primary"> <i class="fas fa-save"></i>   @(Model?.Id > 0 ? "Update" : "Save")</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



