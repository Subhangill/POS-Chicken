@model List<POS.Models.Production>

<div class="page-wrapper">
    <div class="content">
        <div class="row">
            <div class="col-sm-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="card-title">Production List</h4>
                        <a asp-action="Create" class="btn btn-primary rounded"><i class="fa fa-plus"></i> Create</a>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table datatable table-bordered">
                                <thead >
                                    <tr>
                                        <th width="10%" class="text-center">SR</th>
                                        <th width="25%">Date</th>
                                        <th width="10%" class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <thead class="custom">
                                    <tr>
                                        <th class="p-1"><input type="text" class="form-control form-control-sm col-search" placeholder="Search Sr" /></th>
                                        <th class="p-1"><input type="text" class="form-control form-control-sm col-search" placeholder="Search Date" /></th>
                                        <th class="p-1 text-center"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int SR = 1; }
                                    @foreach (var item in Model.Where(x => x.IsDelete == 0).OrderByDescending(x => x.Id))
                                    {
                                        <tr>
                                            <td class="text-center">@SR</td>
                                            <td>@item.Date.ToString("yyyy-MM-dd")</td>
                                            <td class="text-center">
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm" title="Edit"><i class="fas fa-pencil"></i></a>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" title="Delete" onclick="return confirm('Are you sure you want to delete this production record?')"><i class="fas fa-trash"></i></a>
                                            </td>
                                        </tr>
                                        SR++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
