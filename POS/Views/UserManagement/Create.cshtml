@model UserVm

<div class="page-wrapper">
    <div class="content">
        <div class="row">
            <div class="col-sm-12">
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center ">
                        <h3 class="card-title mb-0"><i class="fas fa-user-tag mr-2"></i>@(Model.UserLogin.Id > 0 ? "Update User" : "Add User")</h3>
                        <a asp-action="Index" class="btn btn-primary rounded"><i class="fa fa-list mr-1"></i> List</a>
                    </div>
                    <div class="card-body">
                        <form asp-action="Save" method="post" enctype="multipart/form-data">
                            <input asp-for="UserLogin.Id" type="hidden" />
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label asp-for="UserLogin.Username" class="form-label">Username <span class="text-danger">*</span></label>
                                    <input asp-for="UserLogin.Username" class="form-control" placeholder="Enter username" required />
                                    <span asp-validation-for="UserLogin.Username" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="UserLogin.Password" class="form-label">Password <span class="text-danger">*</span></label>
                                    <input asp-for="UserLogin.Password" type="password" class="form-control" placeholder="Enter password" required />
                                    <span asp-validation-for="UserLogin.Password" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label asp-for="UserLogin.EmpId" class="form-label">Employee <span class="text-danger">*</span></label>
                                    <select asp-for="UserLogin.EmpId" asp-items="@(new SelectList(Model.Employeelist, "Id", "Name"))" class="search-select" required>
                                        <option value="">-- Select Employee --</option>
                                    </select>
                                    <span asp-validation-for="UserLogin.EmpId" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="UserLogin.RoleId" class="form-label">Role <span class="text-danger">*</span></label>
                                    <select asp-for="UserLogin.RoleId" asp-items="@(new SelectList(Model.Rolelist, "Id", "Name"))" class="search-select" required>
                                        <option value="">-- Select Role --</option>
                                    </select>
                                    <span asp-validation-for="UserLogin.RoleId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="text-center">
                                <button type="submit" class="btn btn-primary px-4">
                                    <i class="ti ti-device-floppy me-1"></i> Save
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
