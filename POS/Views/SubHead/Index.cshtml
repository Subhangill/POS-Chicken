@model List<Account_SubHead>

<div class="page-wrapper">
    <div class="content">


        <!-- /Page Header -->

        <div class="row">
            <div class="col-sm-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="card-title">Accounts Sub Heads</h4>
                        <a asp-action="Create" class="btn btn-primary rounded "><i class="fa fa-plus mr-1"></i>  Add New</a>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table  class="table datatable table-bordered table-hover ">
                                <thead class="thead-light">
                                    <tr>
                                        <th width="70" class="text-center">Sr</th>
                                        <th>Head</th>
                                        <th>Sub Head</th>
                                        <th width="10" class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <thead class="custom">
                                    <tr>
                                        <th class="p-1"><input type="text" class="form-control form-control-sm input-dt-search" placeholder="Search here.." /></th>
                                        <th class="p-1"><input type="text" class="form-control form-control-sm input-dt-search" placeholder="Search here.." /></th>
                                        <th class="p-1"><input type="text" class="form-control form-control-sm input-dt-search" placeholder="Search here.." /></th>
                                        <th class="p-1 text-center"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Item -->
                                    @{
                                        int SR = 1;
                                    }
                                    @foreach (var items in Model)
                                    {
                                        <tr>
                                            <td class="text-center">@SR</td>
                                            <td>@(items.Headname ?? "N/A")</td>
                                            <td>@(items.Name ?? "N/A")</td>
                                            <td class="text-center">
                                                @if (items.Id > 14)
                                                {
                                                    <a asp-action="Edit" asp-route-id="@items.Id"
                                                       class="btn btn-primary btn-sm " title="Edit">
                                                        <i class="fas fa-pencil "></i>
                                                    </a>
                                                    <a asp-action="Delete"
                                                       asp-route-id="@items.Id"
                                                       class="btn btn-danger btn-sm "
                                                       title="Delete"
                                                       onclick="return confirm('Are you sure you want to delete this record?')">
                                                        <i class=" fas fa-trash"> </i>
                                                    </a>
                                                }
                                                else
                                                {
                                                   <span class="text-dark fw-bold"> <i class="fa fa-lock"></i> System Account</span> 
                                                }


                                            </td>
                                        </tr>
                                        SR++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>