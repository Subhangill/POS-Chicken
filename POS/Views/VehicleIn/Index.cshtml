@model List<POS.Models.VehicleInView>

<div class="page-wrapper">
    <div class="content">
        <div class="row">
            <div class="col-sm-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="card-title">Vehicle In Transactions List</h4>
                        <a asp-action="Create" class="btn btn-primary rounded"><i class="fa fa-plus"></i> Create Vehicle In</a>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table color table-bordered table-hover bg-white datatable" id="vehicleInIndexTable">
                                <thead >
                                    <tr>
                                        <th width="10%" class="text-center">SR</th>
                                        <th width="20%">Date & Time</th>
                                        <th>Employee Name</th>
                                        <th width="20%">Vehicle Name</th>
                                        <th width="15%" class="text-right">Total Weight</th>
                                        <th width="15%" class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <thead class="custom">
                                    <tr class="search-row">
                                        <th class="p-1"><input type="text" class="form-control form-control-sm col-search" placeholder="Search Sr" /></th>
                                        <th class="p-1"><input type="text" class="form-control form-control-sm col-search" placeholder="Search Date" /></th>
                                        <th class="p-1"><input type="text" class="form-control form-control-sm col-search" placeholder="Search Employee" /></th>
                                        <th class="p-1"><input type="text" class="form-control form-control-sm col-search" placeholder="Search Vehicle" /></th>
                                        <th class="p-1"><input type="text" class="form-control form-control-sm col-search text-right" placeholder="Search Weight" /></th>
                                        <th class="p-1 text-center"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int SR = 1;
                                    }
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="text-center font-weight-bold text-secondary">@SR</td>
                                            <td>@item.date.ToString("dd-MMM-yyyy hh:mm tt")</td>
                                            <td>@item.EmployeeName</td>
                                            <td>
                                                <span class="badge bg-light text-dark border px-2 py-1">
                                                    @item.VehicleName
                                                </span>
                                            </td>
                                            <td class="text-right font-weight-bold">@item.weightTotal.ToString("N2")</td>
                                            <td class="text-center">
                                                <div class="d-inline-flex gap-2">
                                                    <a asp-action="Edit" asp-route-id="@item.id"
                                                       class="btn btn-primary btn-sm px-2" title="Edit Vehicle In">
                                                        <i class="fas fa-pencil-alt"></i>
                                                    </a>
                                                    <a asp-action="Delete" asp-route-id="@item.id"
                                                       class="btn btn-danger btn-sm px-2" title="Delete Vehicle In"
                                                       onclick="return confirm('Are you sure you want to delete this record?')">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                    <a asp-action="Print" asp-route-id="@item.id" target="_blank"
                                                       class="btn btn-info btn-sm px-2 text-white" title="Print Vehicle In">
                                                        <i class="fas fa-print"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                        SR++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


